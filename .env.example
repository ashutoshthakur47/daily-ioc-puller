# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env to GitHub - it's in .gitignore
# For local testing only. In production, use environment variables.

# Get from: https://auth.abuse.ch/
ABUSECH_AUTH_KEY=your_abuse_ch_auth_key_here

# Get from: https://otx.alienvault.com/settings/api
OTX_API_KEY=your_otx_api_key_here
